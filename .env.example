START_URL=http://251gna/wp_root
ALLOWED_HOSTS=251gna
ROOT_PATH=/wp_root

OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_INDEX=portal_knowledge_base
TIKA_URL=http://tika:9998

DATA_DIR=/app/data
CACHE_DIR=/app/data/cache
KNOWLEDGE_BACKUP_DIR=/app/data/backups
CACHE_RAW_FILES=true
MAX_DEPTH=100
MAX_PAGES=0
MAX_FILE_MB=250
CONCURRENCY=4
REQUEST_DELAY_SECONDS=0.25
REQUEST_TIMEOUT_SECONDS=60
USER_AGENT=PortalSearchAgent/1.0 internal-hospital-search
PUBLIC_BASE_URL=http://localhost:8080
ADMIN_TOKEN=local-admin-change-me
ADMIN_USERNAME=admin
ADMIN_PASSWORD=local-admin-change-me
ADMIN_SESSION_SECRET=local-admin-change-me
ADMIN_SESSION_HOURS=12
ADMIN_COOKIE_SECURE=false

OCR_LANGUAGES=ell+eng
CRAWL_CRON=0 2 * * *
SCHEDULER_RESET_EACH_RUN=false

EXTRA_FILE_ROOTS=
EXCLUDE_PATTERNS=/wp-admin,/wp-login.php,/xmlrpc.php,/wp-json/,?feed=,/feed/,/comments/feed,?s=
